+    # 2. One Newton step: z₁ = (C − φ(z₀)) / Φ(z₀)
+    phi_z0 = exp(-z0 * z0 / 2) / sqrt(FT(2) * FT(π))
+    return (C - phi_z0) / cf0_safe
