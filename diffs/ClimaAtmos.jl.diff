+        viz.plot!(
+            gl,
+            var;
+            more_kwargs = Dict(
+                :axis => ca_kwargs(
+                    title = parse_var_attributes(var),
+                ),
+                :plot => ca_kwargs(
+                    colormap = Makie.Reverse(:RdBu),
+                    colorrange = crange,
+                ),
