+    weight = sgs_weight_function(denominator, half)
+    return ifelse(
+        denominator < ϵ, zero(numerator),
+        weight * numerator / denominator,
+    )
+end
+
+"""
+    rime_mass_fraction(q_rim, q_ice, q_ice_half)
